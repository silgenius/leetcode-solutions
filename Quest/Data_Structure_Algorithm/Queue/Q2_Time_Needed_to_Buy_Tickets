/**
 * @param {number[]} tickets
 * @param {number} k
 * @return {number}
 */
var timeRequiredToBuy = function (tickets, k) {
  let count = 0;
  for (let i = 0; i < tickets.length; i++)
    if (i <= k) {
      count += tickets[i] < tickets[k] ? tickets[i] : tickets[k];
    } else {
      count += tickets[i] < tickets[k] ? tickets[i] : tickets[k] - 1;
    }

  return count;
};
